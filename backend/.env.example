# App Configuration
APP_NAME=TruckerGPS API
SECRET_KEY=your-super-secret-key-change-this-in-production-use-256-bit-random

# Database (PostgreSQL with PostGIS extension)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/truckergps

# Redis (for caching and real-time WebSocket pub/sub)
REDIS_URL=redis://localhost:6379/0

# ─── Routing: OpenRouteService (FREE - 2000 req/day) ───────────────────────────
# Get free API key at: https://openrouteservice.org/dev/#/login
ORS_API_KEY=your_ors_api_key_here

# ─── Weather: Open-Meteo (100% FREE - no key needed) ────────────────────────── 
# Open-Meteo doesn't need an API key! Weather endpoints work without it.

# ─── Weather Tiles: OpenWeatherMap (FREE tier: 60 calls/min) ─────────────────
# Get free API key at: https://openweathermap.org/api
OWM_API_KEY=your_owm_api_key_here

# ─── Fuel Prices: EIA API (FREE - US Government) ─────────────────────────────
# Get free API key at: https://www.eia.gov/opendata/register.php
# Without this key, app uses estimated regional prices
EIA_API_KEY=your_eia_api_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In production, set this to your Flutter app's domain
ALLOWED_ORIGINS=["*"]

# ─── Debug ────────────────────────────────────────────────────────────────────
DEBUG=false
